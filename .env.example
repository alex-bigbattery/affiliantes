# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to ".env" and fill in the values. NEVER commit the real .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── BACKEND vars (set these on RENDER) ───────────────────────────────────────

# AffiliateWP REST API (bigbattery.com)
AFFWP_PUBLIC_KEY=
AFFWP_TOKEN=
AFFWP_SECRET_KEY=

# WooCommerce REST API (bigbattery.com) — coupons catalog
WOO_STORE_URL=https://bigbattery.com
WOO_CONSUMER_KEY=
WOO_CONSUMER_SECRET=
# Must be Read/Write (not Read-only) for bulk Update from the dashboard API.

# WordPress admin login — only for local browser automation (npm run wc:admin-update)
WP_ADMIN_USER=
WP_ADMIN_PASSWORD=
WC_ADMIN_PRE_UPDATE_DELAY_MS=10000
WC_ADMIN_AFFILIATE_WAIT_MS=10000
WC_ADMIN_DELAY_MS=3000

# Supabase Postgres (same DB as the commission project).
# On Render use the TRANSACTION pooler (port 6543), not session mode (5432):
#   Project Settings → Database → Connection string → Transaction pooler
# Session mode is limited to ~15 clients total across all apps.
DATABASE_URL=
# Max pg connections per API instance (default 3). Keep low on Supabase free/pro.
PG_POOL_MAX=3

# Supabase project URL (public, not secret)
SUPABASE_URL=https://evgmeszyxjzrrbrzznhv.supabase.co

# How often to sync AffiliateWP -> Supabase (minutes)
SYNC_INTERVAL_MINUTES=30

# Comma-separated allowed origins for CORS = your Vercel frontend URL(s).
# Leave empty for local dev. Example: https://affiliate-dashboard.vercel.app
ALLOWED_ORIGINS=

# Port (Render sets this automatically; 3001 for local)
PORT=3001

# ── FRONTEND var (set this on VERCEL, build-time) ────────────────────────────

# Render backend URL (no trailing slash). Use for `npm run dev:client` → calls Render API directly.
# Localhost is allowed by CORS in server.js — no need to add it to ALLOWED_ORIGINS on Render.
# Alternative: leave empty and run `npm run dev` (local API on :3001 via Vite proxy).
# Example: https://affiliate-dashboard-api-n10y.onrender.com
VITE_API_URL=https://affiliate-dashboard-api-n10y.onrender.com
