{
  "name": "affiliate-dashboard",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev:server": "node --watch server.js",
    "dev:client": "vite --port 5174",
    "dev": "concurrently -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "build": "vite build",
    "start": "NODE_ENV=production node server.js",
    "sync:woo": "node scripts/sync-woo-coupons.js",
    "configure:render-woo": "node scripts/configure-render-woo-env.js",
    "sync:coupon-map": "node scripts/sync-coupon-map.js",
    "sync:wc-orders": "node scripts/sync-wc-orders.js",
    "sync:wc-order-details": "node scripts/backfill-wc-order-details.js",
    "wc:update-affiliate": "node scripts/bulk-wc-order-update.js",
    "wc:admin-update": "node scripts/wc-admin-bulk-update.js",
    "audit:referrals": "node scripts/affiliate-referral-audit.js",
    "seed:dashboard-users": "node scripts/seed-dashboard-users.js",
    "restore:render-env": "node scripts/restore-render-env.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.1",
    "axios": "^1.7.2",
    "cors": "^2.8.5",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "lucide-react": "^0.390.0",
    "pg": "^8.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1",
    "recharts": "^2.12.7",
    "ws": "^8.21.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "playwright": "^1.60.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "vite": "^5.3.1"
  }
}
